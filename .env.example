# ============================================================
#  CiteRAG — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  Cloud vars take priority over local host/port when set.
# ============================================================

# ── Qdrant Configuration ─────────────────────────────────────
# Local (Docker or native binary):
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Cloud (Qdrant Cloud — overrides host/port when both are set):
# QDRANT_URL=https://abc123.aws.cloud.qdrant.io
# QDRANT_API_KEY=your-qdrant-api-key-here

# ── MongoDB Configuration ────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB_NAME=rag_platform

# ── Elasticsearch Configuration ──────────────────────────────
# Local (Docker or native install):
ES_HOST=localhost
ES_PORT=9200

# Cloud (Elastic Cloud Hosted — overrides host/port when ES_URL is set):
# ES_URL=https://abc123.es.ap-south-1.aws.elastic.co
#
# Auth option A — API Key (recommended, get from Cloud console → Security → API Keys):
# ES_API_KEY=your-api-key-here
#
# Auth option B — Basic auth (elastic / password shown at deployment creation):
# ES_USERNAME=elastic
# ES_PASSWORD=your-deployment-password-here

# ── Application Settings ─────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Embedding Model ──────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# ── File Upload Settings ─────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# ── Ollama Settings ──────────────────────────────────────────
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
LLM_MODEL=llama3:8b